@model IEnumerable<ZekterfyDomain.Model.Song>

@{
	ViewData["Title"] = "Пісні";
}

<h1>Пісні @ViewBag.GenreId</h1>

<p>
	@Html.ActionLink("Додати нову пісню", "Create", new { genreId = ViewBag.GenreId })
</p>
<table class="table">
	<thead>
		<tr>
			<th>
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Lenght)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.NumOfStreams)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Name)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.GenreId)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Album)
			</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					<button class="btn btn-success rounded-circle btn-sm"
							onclick="MusicPlayer.addAndPlay(@item.Id, '@item.Name')">
						▶
					</button>
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Lenght)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.NumOfStreams)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Name)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.GenreId)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Album.Name)
				</td>
				<td>
					<div class="btn-group gap-2" role="group">
						<a class="btn btn-sm btn-outline-light" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
						<a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Details</a>
						<a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
					</div>
				</td>
			</tr>
		}
	</tbody>
</table>
